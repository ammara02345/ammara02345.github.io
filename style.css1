/* style.css */
body {
  font-family: Arial, sans-serif;
  margin: 0;
}

.blue-border {
  height: 6px;
  background-color: #007BFF;
}

header {
  text-align: center;
  padding: 2rem 1rem;
}

h1 { color: #007BFF; margin: 0; }

section { padding: 2rem 1rem; border-bottom: 1px solid #ddd; }
section h2 { margin-bottom: 0.5rem; color: #333; }

ul { list-style-type: none; padding-left: 0; }
ul li { margin: 0.5rem 0; }

footer {
  text-align: center;
  padding: 1rem;
  background: #f5f5f5;
}
